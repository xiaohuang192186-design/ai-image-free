# ============================================================================
# AI Free Image Generator — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
# cp .env.example .env.local

# --- Image provider ---
# fal       = 直连 https://fal.run/fal-ai/z-image/turbo （推荐，需 FAL_KEY）
# hf        = HF Router 中转 fal（需 HF_TOKEN）
# dashscope = 阿里云百炼（有内容安全，成人向会被拦）
# auto      = 有 FAL_KEY 用 fal，否则 HF
IMAGE_PROVIDER=fal
# NSFW_MODE=1  禁止百炼；优先 fal 直连
# NSFW_MODE=1
# FAL_SAFETY_CHECKER=
# FAL_INFERENCE_STEPS=8

# --- fal.ai 直连 ---
# https://fal.ai/dashboard/keys
# FAL_KEY=uuid:secret
# FAL_MODEL_URL=https://fal.run/fal-ai/z-image/turbo


# --- Rate limits (protect billing) ---
# RATE_LIMIT_PER_MIN=10
# RATE_LIMIT_PER_IP_DAY=30
# RATE_LIMIT_GLOBAL_DAY=500

# --- Cloudflare Turnstile (optional anti-bot) ---
# https://dash.cloudflare.com → Turnstile → Add site
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4...
# TURNSTILE_SECRET_KEY=0x4...


# --- 阿里云百炼 DashScope（推荐：千问 / z-image 官方）---
# 控制台: https://bailian.console.aliyun.com/
# 创建 API-KEY: https://bailian.console.aliyun.com/?apiKey=1
# 新人常有免费额度，用完按张计费（以官方价格页为准）
# DASHSCOPE_API_KEY=sk-xxxxxxxx
# 模型可选: z-image-turbo | qwen-image | qwen-image-plus | qwen-image-2.0 | qwen-image-2.0-pro
# DASHSCOPE_MODEL=z-image-turbo
# 可选：若控制台要求 MaaS 业务空间 URL，填完整 generation 地址
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# DASHSCOPE_WATERMARK=false
# DASHSCOPE_PROMPT_EXTEND=true
# DASHSCOPE_NEGATIVE_PROMPT=

# --- HuggingFace（备选：Router → fal-ai 跑 Z-Image-Turbo）---
# Token: https://huggingface.co/settings/tokens （Read 即可）
# 注意: 走 Inference Providers，有月赠额度，不是无限免费
HF_TOKEN=hf_your_token_here

# --- Cloudflare R2 Storage ---
# 1. https://dash.cloudflare.com → R2 → Create bucket
# 2. Public access via r2.dev
# 3. Manage R2 API Tokens → Object Read & Write

R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your-bucket-name

# https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com

# https://pub-<hash>.r2.dev
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev

# --- Google AdSense (optional) ---
# NEXT_PUBLIC_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxx

# --- Google Analytics (optional) ---
# NEXT_PUBLIC_GA_ID=G-xxxxxxxxxx
